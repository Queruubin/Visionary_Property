---
const leaders = [
  {
    name: "Victoria Morton",
    role: "President",
    initials: "VM",
    bio: "Victoria is a president of Visionary Property Management of Florida and a Florida Bar licensed attorney admitted to practice before the Florida State Courts, the U.S. District Court for the Southern District of Florida, and the U.S. Supreme Court.",
    highlights: [
      "Florida Bar Licensed Attorney since 2003",
      "B.S. from University of Florida (1998)",
      "Juris Doctorate from Nova Southeastern University",
      "15+ years serving on HOA Board of Directors",
      "23+ years of experience",
      "Specialist in community association law",
      "Former adjunct professor at Palm Beach State College",
      "Licensed Community Association Management",
    ],
    quote:
      "Her experience in representing homeowner and condominium associations gives her a unique perspective on providing management services.",
  },
];
---

<section id="team" class="py-24" style="background: white;">
  <div class="max-w-4xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <span
        class="inline-block text-sm font-semibold uppercase tracking-widest mb-4 px-4 py-1.5 rounded-full"
        style="background: rgba(139,4,4,0.08); color: #8B0404;"
      >
        Meet Our Leadership
      </span>
      <h2 class="text-4xl md:text-5xl font-bold mb-4" style="color: #2a2a2a;">
        Expert you can<br />
        <span style="color: #8B0404;">trust with your community</span>
      </h2>
      <p class="text-lg max-w-2xl mx-auto" style="color: #666;">
        Visionary was founded by an attorney and real estate professional with decades
        of experience in community association management.
      </p>
    </div>

    <!-- Leader card -->
    {
      leaders.map((leader) => (
        <div
          class="rounded-3xl overflow-hidden border shadow-lg"
          style="border-color: rgba(139,4,4,0.1);"
        >
          <!-- Card header -->
          <div
            class="p-8 text-white relative overflow-hidden"
            style="background: linear-gradient(135deg, #8B0404 0%, #5a0202 100%);"
          >
            <div
              class="absolute inset-0 opacity-5"
              style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 30px 30px;"
            />
            <div class="relative z-10 flex items-center gap-6">
              <div
                class="w-20 h-20 rounded-2xl flex items-center justify-center text-2xl font-black border-2 border-white/30"
                style="background: rgba(255,255,255,0.12);"
              >
                {leader.initials}
              </div>
              <div>
                <h3 class="text-2xl font-bold">{leader.name}</h3>
                <p class="font-medium mt-1" style="color: #c0a88c;">{leader.role}</p>
                <p class="text-xs mt-1" style="color: rgba(255,255,255,0.5);">
                  Visionary Property Management of Florida
                </p>
              </div>
            </div>
          </div>

          <!-- Card body -->
          <div class="p-8 md:grid md:grid-cols-2 md:gap-8" style="background: #f5f5f5;">
            <div>
              <p class="text-sm leading-relaxed mb-6" style="color: #555;">
                {leader.bio}
              </p>
              <blockquote
                class="text-sm italic leading-relaxed p-4 rounded-2xl"
                style="background: rgba(164,137,108,0.08); border-left: 3px solid #A4896C; color: #555;"
              >
                "{leader.quote}"
              </blockquote>
            </div>

            <div>
              <h4
                class="text-xs font-bold uppercase tracking-widest mb-4"
                style="color: #8B0404;"
              >
                Key Credentials
              </h4>
              <ul class="space-y-2.5">
                {leader.highlights.map((h) => (
                  <li class="flex items-start gap-2.5 text-sm" style="color: #2a2a2a;">
                    <span
                      class="w-1.5 h-1.5 rounded-full mt-1.5 shrink-0"
                      style="background: #A4896C;"
                    />
                    {h}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
