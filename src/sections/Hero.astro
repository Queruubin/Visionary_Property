---

---

<section
  id="home"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
  style="background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 50%, #2a0101 100%);"
>
  <!-- Animated background orbs -->
  <div
    class="absolute top-20 right-10 w-96 h-96 rounded-full opacity-15 blur-3xl animate-pulse"
    style="background: #6C0302;"
  >
  </div>
  <div
    class="absolute bottom-20 left-10 w-72 h-72 rounded-full opacity-10 blur-3xl animate-pulse"
    style="background: #8a0403; animation-delay: 1s;"
  >
  </div>

  <!-- Grid pattern overlay -->
  <div
    class="absolute inset-0 opacity-5"
    style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"
  >
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center py-32 mt-16">
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold mb-8 border border-white/20 backdrop-blur-sm"
      style="background: rgba(108,3,2,0.25); color: rgba(255,255,255,0.9);"
    >
      <span
        class="w-2 h-2 rounded-full animate-pulse"
        style="background: #6C0302;"></span>
      Trusted Community Association Management · Palm Beach Gardens, FL
    </div>

    <!-- Main headline -->
    <h1
      class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight"
    >
      <span style="color: #e05252;">Visionary Management </span>
      <br />
      is looking towards the future<br />
      while taking care of today.
    </h1>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="#contact"
        class="px-8 py-4 rounded-full text-base font-bold transition-all duration-300 hover:scale-105 hover:shadow-2xl shadow-lg"
        style="background: #6C0302; color: white;"
      >
        Request Information
      </a>
      <a
        href="#services"
        class="px-8 py-4 rounded-full text-base font-semibold border-2 border-white/50 text-white transition-all duration-300 hover:bg-white/10 hover:border-white"
      >
        Explore Our Services →
      </a>
    </div>

    <!-- Stats bar -->
    <div class="mt-20 flex flex-row flex-wrap justify-center gap-6">
      {
        [
          {
            number: "25+",
            label: "Years of Experience in condominium and HOA",
          },
          { number: "100%", label: "Customized Services" },
        ].map((stat) => (
          <div
            class="border rounded-2xl p-5 backdrop-blur-sm"
            style="background: rgba(108,3,2,0.15); border-color: rgba(108,3,2,0.4);"
          >
            <div class="text-3xl font-black mb-1" style="color: #e05252;">
              {stat.number}
            </div>
            <div class="text-sm text-white/60 font-medium">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Wave bottom -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M0 80L1440 80L1440 20C1200 80 960 0 720 20C480 40 240 0 0 20L0 80Z"
        fill="#f5f5f5"></path>
    </svg>
  </div>
</section>
