---
const navLinks = [
  { label: "Home", href: "#home" },
  { label: "About", href: "#about" },
  { label: "Services", href: "#services" },
  { label: "Technology", href: "#technology" },
  { label: "Contact", href: "#contact" },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="#home" class="flex items-center group" id="logo-link">
      <!-- PNG logo — mix-blend-mode:multiply removes white bg on light surfaces -->
      <img
        src="/logo.png"
        alt="Visionary Property Management of Florida LLC"
        id="nav-logo"
        width="160"
        height="60"
        class="transition-all duration-300 group-hover:scale-105"
        style="mix-blend-mode: multiply; object-fit: contain;"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8 list-none">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-md lg:text-base font-semibold transition-all duration-200 hover:opacity-100 relative nav-link"
              id={`nav-${link.label.toLowerCase()}`}
              style="color: #2a2a2a;"
            >
              {link.label}
              <span
                class="absolute -bottom-0.5 left-0 w-0 h-0.5 transition-all duration-300 nav-underline"
                style="background: #A4896C;"
              />
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA Button -->
    <div class="hidden md:flex items-center gap-4">
      <a
        href="#contact"
        id="portal-btn"
        class="px-5 py-2.5 rounded-md text-sm font-semibold border-2 transition-all duration-200"
        style="border-color: #8B0404; color: #8B0404;"
        onmouseover="this.style.background='#8B0404'; this.style.color='white';"
        onmouseout="this.style.background='transparent'; this.style.color='#8B0404'; this.style.borderColor='#8B0404';"
      >
        Portal Access
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Open menu"
    >
      <span class="w-6 h-0.5 block transition-all duration-300 nav-bar" style="background: #2a2a2a;" id="bar1"></span>
      <span class="w-6 h-0.5 block transition-all duration-300 nav-bar" style="background: #2a2a2a;" id="bar2"></span>
      <span class="w-6 h-0.5 block transition-all duration-300 nav-bar" style="background: #2a2a2a;" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden px-6 pb-4 pt-2 border-t"
    style="background: rgba(250,244,238,0.97); border-color: rgba(139,4,4,0.1); backdrop-filter: blur(12px);"
  >
    <ul class="flex flex-col gap-3 list-none">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block font-semibold text-base py-2 border-b transition-colors"
              style="color: #2a2a2a; border-color: rgba(139,4,4,0.08);"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a
          href="#contact"
          class="block text-center px-4 py-2.5 rounded-full text-sm font-semibold text-white transition-all"
          style="background: #8B0404;"
        >
          Portal Access
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar")!;
  const menuBtn = document.getElementById("menu-btn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const navLogo = document.getElementById("nav-logo") as HTMLImageElement;
  const navLinks = document.querySelectorAll(".nav-link");
  const navBars = document.querySelectorAll(".nav-bar");
  const portalBtn = document.getElementById("portal-btn") as HTMLAnchorElement;

  // Scroll effect
  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      // Scrolled: dark solid navbar
      navbar.style.background = "rgba(30,30,30,0.96)";
      navbar.style.boxShadow = "0 4px 30px rgba(0,0,0,0.25)";
      navbar.style.backdropFilter = "blur(12px)";
      // Flip logo blend mode so it looks good on dark bg
      navLogo.style.mixBlendMode = "normal";
      navLogo.style.filter = "brightness(0) invert(1)";
      // White nav links
      navLinks.forEach((l) => ((l as HTMLElement).style.color = "rgba(255,255,255,0.9)"));
      navBars.forEach((b) => ((b as HTMLElement).style.background = "white"));
      portalBtn.style.borderColor = "white";
      portalBtn.style.color = "white";
      portalBtn.onmouseover = () => {
        portalBtn.style.background = "white";
        portalBtn.style.color = "#8B0404";
      };
      portalBtn.onmouseout = () => {
        portalBtn.style.background = "transparent";
        portalBtn.style.color = "white";
        portalBtn.style.borderColor = "white";
      };
    } else {
      // Top: transparent navbar, logo shows on beige bg with multiply
      navbar.style.background = "transparent";
      navbar.style.boxShadow = "none";
      navbar.style.backdropFilter = "none";
      navLogo.style.mixBlendMode = "multiply";
      navLogo.style.filter = "none";
      navLinks.forEach((l) => ((l as HTMLElement).style.color = "#2a2a2a"));
      navBars.forEach((b) => ((b as HTMLElement).style.background = "#2a2a2a"));
      portalBtn.style.borderColor = "#8B0404";
      portalBtn.style.color = "#8B0404";
      portalBtn.onmouseover = () => {
        portalBtn.style.background = "#8B0404";
        portalBtn.style.color = "white";
      };
      portalBtn.onmouseout = () => {
        portalBtn.style.background = "transparent";
        portalBtn.style.color = "#8B0404";
        portalBtn.style.borderColor = "#8B0404";
      };
    }
  });

  // Mobile menu toggle
  menuBtn.addEventListener("click", () => {
    mobileMenu.classList.toggle("hidden");
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
    });
  });

  // Nav link hover underline
  document.querySelectorAll(".nav-link").forEach((link) => {
    const underline = link.querySelector(".nav-underline") as HTMLElement;
    link.addEventListener("mouseenter", () => {
      if (underline) underline.style.width = "100%";
    });
    link.addEventListener("mouseleave", () => {
      if (underline) underline.style.width = "0%";
    });
  });
</script>
