---
const navLinks = [
  { label: "Home", href: "#home" },
  { label: "About", href: "#about" },
  { label: "Services", href: "#services" },
  { label: "Technology", href: "#technology" },
  { label: "Contact", href: "#contact" },
];
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-colors duration-300"
>
  <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
    <!-- Navbar logo — real SEO logo with descriptive alt and link.
         Starts opacity:0, GSAP fades it in at end of morph. -->
    <a
      href="#home"
      class="flex items-center group"
      aria-label="Visionary Property Management of Florida LLC"
    >
      <img
        src="/logo.png"
        alt="Visionary Property Management of Florida LLC"
        id="nav-logo"
        width="300"
        height="200"
        class="object-contain transition-transform duration-300 group-hover:scale-105"
        style="opacity: 0; will-change: opacity, filter; mix-blend-mode: multiply; height: 100px; width: auto; max-width: 180px;"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8 list-none">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link text-base font-semibold transition-colors duration-200 relative"
              style="color: #2a2a2a;"
            >
              {link.label}
              <span
                class="nav-underline absolute -bottom-0.5 left-0 w-0 h-0.5 transition-all duration-300"
                style="background: #A4896C;"
              />
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA Button -->
    <div class="hidden md:flex items-center">
      <a
        href="https://app.payhoa.com/sign-up/28347-millake-homeowners-association-inc"
        target="_blank"
        id="portal-btn"
        class="px-5 py-2.5 rounded-md text-sm font-semibold border-2 transition-all duration-200"
        style="border-color: #8B0404; color: #8B0404;"
      >
        Portal Access
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Open menu"
    >
      <span
        class="nav-bar w-6 h-0.5 block transition-all duration-300"
        style="background: #2a2a2a;"
        id="bar1"></span>
      <span
        class="nav-bar w-6 h-0.5 block transition-all duration-300"
        style="background: #2a2a2a;"
        id="bar2"></span>
      <span
        class="nav-bar w-6 h-0.5 block transition-all duration-300"
        style="background: #2a2a2a;"
        id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden px-6 pb-4 pt-2 border-t"
    style="background: rgba(250,244,238,0.97); border-color: rgba(139,4,4,0.1); backdrop-filter: blur(12px);"
  >
    <ul class="flex flex-col gap-3 list-none">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="block font-semibold text-base py-2 border-b transition-colors"
              style="color: #2a2a2a; border-color: rgba(139,4,4,0.08);"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a
          href="https://app.payhoa.com/sign-up/28347-millake-homeowners-association-inc"
          target="_blank"
          class="block text-center px-4 py-2.5 rounded-full text-sm font-semibold text-white"
          style="background: #8B0404;"
        >
          Portal Access
        </a>
      </li>
    </ul>
  </div>
</nav>

<!--
  Transit logo — a fixed-positioned visual clone of the hero logo.
  GSAP animates it from hero position → navbar position using
  x, y, scale (transform-only = no layout recalculation, CLS = 0).
  aria-hidden + alt="" so screen readers never read it.
-->
<img
  id="transit-logo"
  src="/logo.png"
  alt=""
  aria-hidden="true"
  role="presentation"
  style="
    display: none;
    position: fixed;
    z-index: 60;
    pointer-events: none;
    object-fit: contain;
    will-change: transform, opacity;
    transform-origin: top left;
    mix-blend-mode: multiply;
  "
/>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ─── DOM refs ────────────────────────────────────────────────────────────────
  const navbar = document.getElementById("navbar")!;
  const navLogo = document.getElementById("nav-logo") as HTMLImageElement;
  const heroLogo = document.getElementById("hero-logo-img") as HTMLImageElement;
  const transit = document.getElementById("transit-logo") as HTMLImageElement;
  const portalBtn = document.getElementById("portal-btn") as HTMLAnchorElement;
  const menuBtn = document.getElementById("menu-btn")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  let navIsDark = false;
  let morphTween: gsap.core.Timeline | null = null;
  let hasMorphed = false;

  // ─── Dark/light navbar UI helpers ────────────────────────────────────────────
  function applyDark(isDark: boolean) {
    navIsDark = isDark;
    if (isDark) {
      navbar.style.background = "rgba(30,30,30,0.96)";
      navbar.style.boxShadow = "0 4px 30px rgba(0,0,0,0.25)";
      navbar.style.backdropFilter = "blur(12px)";
      document
        .querySelectorAll<HTMLElement>(".nav-link")
        .forEach((l) => (l.style.color = "rgba(255,255,255,0.9)"));
      document
        .querySelectorAll<HTMLElement>(".nav-bar")
        .forEach((b) => (b.style.background = "white"));
      portalBtn.style.borderColor = "white";
      portalBtn.style.color = "white";
      // Nav logo: flip to white on dark bg
      navLogo.style.filter = "brightness(0) invert(1)";
      navLogo.style.mixBlendMode = "normal";
    } else {
      navbar.style.background = "transparent";
      navbar.style.boxShadow = "none";
      navbar.style.backdropFilter = "none";
      document
        .querySelectorAll<HTMLElement>(".nav-link")
        .forEach((l) => (l.style.color = "#2a2a2a"));
      document
        .querySelectorAll<HTMLElement>(".nav-bar")
        .forEach((b) => (b.style.background = "#2a2a2a"));
      portalBtn.style.borderColor = "#8B0404";
      portalBtn.style.color = "#8B0404";
      navLogo.style.filter = "none";
      navLogo.style.mixBlendMode = "multiply";
    }
    // Transit logo mirrors the same color inversion
    if (transit.style.display !== "none") {
      transit.style.filter = isDark ? "brightness(0) invert(1)" : "none";
      transit.style.mixBlendMode = isDark ? "normal" : "multiply";
    }
  }

  function resetToTopState(immediate = true) {
    hasMorphed = false;
    morphTween?.kill();
    morphTween = null;
    gsap.killTweensOf([heroLogo, navLogo, transit]);

    if (immediate) {
      gsap.set(heroLogo, { opacity: 1 });
      gsap.set(navLogo, { opacity: 0 });
      gsap.set(transit, {
        display: "none",
        clearProps:
          "left,top,width,height,x,y,scale,opacity,filter,mixBlendMode",
      });
      applyDark(false);
    }
  }

  function morphBackToHero() {
    if (!hasMorphed) {
      resetToTopState(true);
      return;
    }

    hasMorphed = false;
    morphTween?.kill();
    morphTween = null;
    gsap.killTweensOf([heroLogo, navLogo, transit]);

    const hRect = heroLogo.getBoundingClientRect();
    const nRect = navLogo.getBoundingClientRect();
    const scaleRatio = nRect.width / hRect.width;
    const targetX = nRect.left - hRect.left;
    const targetY = nRect.top - hRect.top;

    gsap.set(transit, {
      display: "block",
      left: hRect.left,
      top: hRect.top,
      width: hRect.width,
      height: "auto",
      x: targetX,
      y: targetY,
      scale: scaleRatio,
      opacity: 1,
      filter: navIsDark ? "brightness(0) invert(1)" : "none",
      mixBlendMode: navIsDark ? "normal" : "multiply",
    });

    morphTween = gsap.timeline({ defaults: { overwrite: "auto" } });

    morphTween
      .to(navLogo, { opacity: 0, duration: 0.12, ease: "power1.out" }, 0)
      .to(
        transit,
        {
          x: 0,
          y: 0,
          scale: 1,
          ease: "power2.out",
          duration: 0.45,
        },
        0,
      )
      .to(heroLogo, { opacity: 1, duration: 0.16, ease: "power1.out" }, 0.3)
      .to(transit, { opacity: 0, duration: 0.1, ease: "power1.out" }, 0.34)
      .eventCallback("onComplete", () => {
        gsap.set(transit, {
          display: "none",
          clearProps:
            "left,top,width,height,x,y,scale,opacity,filter,mixBlendMode",
        });
        applyDark(false);
      });
  }

  function morphToNavbar() {
    if (hasMorphed) return;
    hasMorphed = true;

    const hRect = heroLogo.getBoundingClientRect();
    const nRect = navLogo.getBoundingClientRect();
    const scaleRatio = nRect.width / hRect.width;
    const targetX = nRect.left - hRect.left;
    const targetY = nRect.top - hRect.top;

    gsap.set(transit, {
      display: "block",
      left: hRect.left,
      top: hRect.top,
      width: hRect.width,
      height: "auto",
      x: 0,
      y: 0,
      scale: 1,
      opacity: 1,
      filter: "none",
      mixBlendMode: "multiply",
    });

    gsap.to(heroLogo, { opacity: 0, duration: 0.12, ease: "power1.out" });
    applyDark(true);

    morphTween?.kill();
    morphTween = gsap.timeline({ defaults: { overwrite: "auto" } });

    morphTween
      .to(transit, {
        x: targetX,
        y: targetY,
        scale: scaleRatio,
        transformOrigin: "top left",
        ease: "power3.out",
        duration: 0.55,
      })
      .to(transit, { opacity: 0, duration: 0.12, ease: "power1.out" }, "-=0.12")
      .to(navLogo, { opacity: 1, duration: 0.16, ease: "power1.out" }, "-=0.06")
      .eventCallback("onComplete", () => {
        transit.style.display = "none";
      });
  }

  // ─── Core animation init (called on load + resize) ───────────────────────────
  function initMorph() {
    // Kill any previous ScrollTrigger instances to avoid stacking on resize
    ScrollTrigger.getAll().forEach((t) => t.kill());

    resetToTopState(true);

    const heroSection = document.getElementById("home")!;

    ScrollTrigger.create({
      trigger: heroSection,
      start: "top+=20 top",
      end: "max",
      onEnter: morphToNavbar,
      onEnterBack: morphToNavbar,
      onLeaveBack: morphBackToHero,
    });

    if (window.scrollY > 20) {
      morphToNavbar();
    }
  }

  // ─── Wait for images to load so getBoundingClientRect is accurate ─────────────
  if (document.readyState === "complete") {
    initMorph();
  } else {
    window.addEventListener("load", initMorph, { once: true });
  }

  // ─── Re-init on resize (recalculate positions) ─────────────────────────────
  let _resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(_resizeTimer);
    _resizeTimer = setTimeout(() => {
      initMorph();
      ScrollTrigger.refresh();
    }, 200);
  });

  // ─── Nav link hover underline ─────────────────────────────────────────────
  document.querySelectorAll(".nav-link").forEach((link) => {
    const underline = link.querySelector<HTMLElement>(".nav-underline");
    link.addEventListener("mouseenter", () => {
      if (underline) underline.style.width = "100%";
    });
    link.addEventListener("mouseleave", () => {
      if (underline) underline.style.width = "0%";
    });
  });

  // ─── Portal button hover ──────────────────────────────────────────────────
  portalBtn.addEventListener("mouseenter", () => {
    portalBtn.style.background = navIsDark ? "white" : "#8B0404";
    portalBtn.style.color = navIsDark ? "#8B0404" : "white";
  });
  portalBtn.addEventListener("mouseleave", () => {
    portalBtn.style.background = "transparent";
    portalBtn.style.borderColor = navIsDark ? "white" : "#8B0404";
    portalBtn.style.color = navIsDark ? "white" : "#8B0404";
  });

  // ─── Mobile menu ─────────────────────────────────────────────────────────
  menuBtn.addEventListener("click", () =>
    mobileMenu.classList.toggle("hidden"),
  );
  mobileMenu
    .querySelectorAll("a")
    .forEach((a) =>
      a.addEventListener("click", () => mobileMenu.classList.add("hidden")),
    );
</script>
