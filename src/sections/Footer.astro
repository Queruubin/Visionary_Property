---
const navLinks = [
  { label: "Home", href: "#home" },
  { label: "About", href: "#about" },
  { label: "Services", href: "#services" },
  { label: "Technology", href: "#technology" },
  { label: "Contact", href: "#contact" },
];

const serviceLinks = [
  "Management Services",
  "Bookkeeping",
  "Maintenance Services",
  "Website Services",
];
---

<footer id="contact" style="background: #1e1e1e;">
  <!-- Top section -->
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand column -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-3 mb-5">
          <div
            class="w-10 h-10 rounded-lg flex items-center justify-center"
            style="background: #8B0404;"
          >
            <span class="text-white font-black text-lg">V</span>
          </div>
          <div>
            <div class="font-black text-white text-base">Visionary</div>
            <div
              class="text-xs font-medium"
              style="color: rgba(255,255,255,0.45);"
            >
              Property Management of Florida
            </div>
          </div>
        </div>
        <p class="text-sm text-white/60 leading-relaxed max-w-sm mb-6">
          Visionary Property Management of Florida delivers comprehensive,
          technology-driven community association management in South Florida.
          Partnering with your community to create a better today and tomorrow.
        </p>
        <!-- Contact info -->
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <span class="text-lg mt-0.5">📍</span>
            <span class="text-sm text-white/60">Boynton Beach, FL</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg">📞</span>
            <a
              href="tel:5613403366"
              class="text-sm text-white/60 hover:text-white transition-colors"
            >
              561.340.3366
            </a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-lg">🌐</span>
            <a
              href="https://www.visionarypartners.com"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-white/60 hover:text-white transition-colors"
            >
              www.visionarypartners.com
            </a>
          </div>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="font-bold text-white mb-5 text-sm uppercase tracking-widest">
          Navigation
        </h4>
        <ul class="space-y-3 list-none">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/60 hover:text-white hover:translate-x-1 transition-all inline-flex items-center gap-1.5"
                >
                  <span
                    class="w-1 h-1 rounded-full"
                    style="background: #A4896C;"
                  />
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-bold text-white mb-5 text-sm uppercase tracking-widest">
          Our Services
        </h4>
        <ul class="space-y-3 list-none">
          {
            serviceLinks.map((service) => (
              <li>
                <a
                  href="#services"
                  class="text-sm text-white/60 hover:text-white hover:translate-x-1 transition-all inline-flex items-center gap-1.5"
                >
                  <span
                    class="w-1 h-1 rounded-full"
                    style="background: #A4896C;"
                  />
                  {service}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Contact CTA banner -->
    <div
      class="mt-14 rounded-3xl p-8 md:p-10 flex flex-col md:flex-row items-center justify-between gap-6 border"
      style="background: rgba(139,4,4,0.12); border-color: rgba(139,4,4,0.25);"
    >
      <div>
        <h3 class="text-xl md:text-2xl font-bold text-white mb-1">
          Ready to transform your community?
        </h3>
        <p class="text-white/50 text-sm">
          Contact us today for a free consultation.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 shrink-0">
        <a
          href="tel:5613403366"
          class="px-6 py-3 rounded-full text-sm font-semibold text-white border-2 border-white/30 hover:bg-white/10 transition-all"
        >
          📞 Call Us
        </a>
        <a
          href="mailto:info@visionarypartners.com"
          class="px-6 py-3 rounded-full text-sm font-bold transition-all hover:scale-105"
          style="background: #A4896C; color: white;"
        >
          ✉️ Send an Email
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t" style="border-color: rgba(255,255,255,0.06);">
    <div
      class="max-w-7xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3"
    >
      <p class="text-xs text-white/30">
        © {new Date().getFullYear()} Visionary Property Management of Florida. All
        rights reserved.
      </p>
      <div class="flex items-center gap-5">
        <a
          href="#"
          class="text-xs text-white/30 hover:text-white/60 transition-colors"
        >
          Privacy Policy
        </a>
        <a
          href="#"
          class="text-xs text-white/30 hover:text-white/60 transition-colors"
        >
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
